{
    "name": "mivento/filament-spreadsheet-editor",
    "description": "A Filament v5 plugin that provides an Excel-like spreadsheet editor for Eloquent models.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "filament",
        "laravel",
        "livewire",
        "spreadsheet",
        "tabulator"
    ],
    "authors": [
        {
            "name": "Mivento"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "illuminate/bus": "^11.0|^12.0",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/filesystem": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/validation": "^11.0|^12.0",
        "livewire/livewire": "^4.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Mivento\\FilamentSpreadsheetEditor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mivento\\FilamentSpreadsheetEditor\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "format": "pint",
        "test": "pest"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mivento\\FilamentSpreadsheetEditor\\FilamentSpreadsheetEditorServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
